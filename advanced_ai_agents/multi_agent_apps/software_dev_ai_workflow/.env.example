# Copy this file to .env and fill in only the integrations you need.

# Server
PORT=8901

# Optional: enable six-stage multi-agent workflow output.
# Set to cc-switch to read the current Codex provider from ~/.cc-switch.
AI_CONFIG_SOURCE=env
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT_MS=600000

# Optional: enable GitHub issue creation.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Optional: enable Jira issue creation.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
